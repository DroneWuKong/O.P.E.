OPE_ENV=local
OPE_SERVICE_NAME=ope-core
OPE_DEFAULT_PROJECT=ope-core
OPE_DISABLE_EVENT_LOGGING=false
OPE_REQUIRE_API_KEY=false
OPE_API_KEYS=replace-with-local-api-key
OPE_RUN_MIGRATIONS_ON_STARTUP=true
OPE_STARTUP_RETRY_SECONDS=120
OPE_STARTUP_RETRY_INTERVAL_SECONDS=5
OPE_EXTERNAL_CONNECT_TIMEOUT_SECONDS=5

LITELLM_BASE_URL=http://litellm:4000
LITELLM_MODEL=deep_reasoning
LITELLM_API_KEY=replace-with-local-router-key

POSTGRES_DSN=postgresql://ope:ope-local-dev@postgres:5432/ope
REDIS_URL=redis://redis:6379/0

# Local-only placeholders. Do not place real provider values in this public repo.
OPENAI_API_KEY=replace-with-local-value
ANTHROPIC_API_KEY=replace-with-local-value
GEMINI_API_KEY=replace-with-local-value
MISTRAL_API_KEY=replace-with-local-value
LITELLM_MASTER_KEY=replace-with-local-router-key

# Connector placeholders. Keep real values in private env/Kubernetes/GitHub secrets.
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ENABLED=true
GMAIL_ENABLED=false
GMAIL_ACCESS_TOKEN=
